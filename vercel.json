{
  "version": 2,
  "builds": [
    {
      "src": "backend/app/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend-v2/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/app/main.py"
    },
    {
      "source": "/health",
      "destination": "backend/app/main.py"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/frontend-v2/assets/$1"
    },
    {
      "source": "/favicon.svg",
      "destination": "/frontend-v2/favicon.svg"
    },
    {
      "source": "/((?!api|health|assets|favicon.svg).*)",
      "destination": "/frontend-v2/index.html"
    }
  ],
  "env": {
    "PYTHONPATH": "backend"
  }
}





