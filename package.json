{
  "name": "mailpilot-ai-assistant",
  "version": "1.0.0",
  "scripts": {
    "build": "cd frontend-v2 && npm install && npm run build",
    "install-all": "npm install && cd frontend-v2 && npm install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && python -m uvicorn app.main:app --host 0.0.0.0 --port 8002 --reload",
    "dev:frontend": "cd frontend-v2 && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
